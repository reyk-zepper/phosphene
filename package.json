{
  "name": "@reyk-zepper/phosphene",
  "version": "0.1.43",
  "type": "module",
  "description": "See how AI thinks. Open-source AI reasoning visualizer.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reyk-zepper/phosphene.git"
  },
  "homepage": "https://github.com/reyk-zepper/phosphene#readme",
  "bugs": {
    "url": "https://github.com/reyk-zepper/phosphene/issues"
  },
  "keywords": [
    "ai",
    "reasoning",
    "visualization",
    "trace",
    "graph",
    "typescript",
    "observability"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist-packages",
    "dist-types",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist-types/packages/index.d.ts",
      "import": "./dist-packages/index.js",
      "default": "./dist-packages/index.js"
    },
    "./parser": {
      "types": "./dist-types/packages/parser.d.ts",
      "import": "./dist-packages/parser.js",
      "default": "./dist-packages/parser.js"
    },
    "./graph": {
      "types": "./dist-types/packages/graph.d.ts",
      "import": "./dist-packages/graph.js",
      "default": "./dist-packages/graph.js"
    }
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:packages": "rm -rf dist-types dist-packages && tsc -p tsconfig.packages.json && node scripts/normalize-package-declarations.mjs && vite build --config vite.packages.config.ts",
    "test:packages": "vitest run tests/packages tests/tooling/vitestConfig.test.ts tests/tooling/eslintConfig.test.ts",
    "verify:packages": "pnpm --silent test:packages 1>&2 && pnpm --silent lint 1>&2 && pnpm --silent build 1>&2 && pnpm --silent pack:packages 1>&2 && pnpm --silent smoke:packages 1>&2 && pnpm --silent typecheck:packages",
    "pack:packages": "pnpm --silent build:packages 1>&2 && npm pack --dry-run --json",
    "smoke:packages": "pnpm --silent build:packages 1>&2 && node scripts/smoke-package-consumer.mjs",
    "typecheck:packages": "pnpm --silent build:packages 1>&2 && node scripts/typecheck-package-consumer.mjs",
    "publish:packages:dry-run": "pnpm --silent verify:packages 1>&2 && npm publish --dry-run --ignore-scripts --access public --json",
    "prepublishOnly": "pnpm --silent verify:packages",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest",
    "validate:traces": "node scripts/validate-boundary-traces.mjs",
    "publish:snapshot": "node scripts/publish-snapshot.mjs",
    "generate:canary": "node scripts/generate-ai-node-canary-snapshot.mjs",
    "generate:live-adapter": "node scripts/generate-ai-node-live-adapter-snapshot.mjs",
    "generate:hermes-live-adapter": "node scripts/generate-ai-node-hermes-live-adapter-snapshot.mjs",
    "generate:service-live-adapters": "node scripts/generate-ai-node-service-live-adapters-snapshot.mjs",
    "launch:preflight": "node scripts/launch-preflight.mjs",
    "release:preflight": "node scripts/release-preflight.mjs"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "dagre": "^0.8.5",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.26.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/d3": "^7.4.3",
    "@types/dagre": "^0.7.52",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
