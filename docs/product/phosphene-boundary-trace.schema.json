{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phosphene.local/schemas/phosphene-boundary-trace-v0.1.2.schema.json",
  "title": "Phosphene Boundary Trace v0.1.2",
  "type": "object",
  "required": ["schema_version", "metadata", "events"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "phosphene.boundary.v0.1.2"
    },
    "metadata": {
      "type": "object",
      "required": ["id", "title", "status"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "subtitle": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["queued", "running", "needs_approval", "approved", "denied", "succeeded", "failed", "recovered"]
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["trace_id", "run_id", "source", "event_type", "status", "timestamp", "summary"],
        "additionalProperties": false,
        "properties": {
          "trace_id": {
            "type": "string",
            "minLength": 1
          },
          "run_id": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "enum": ["hermes", "openclaw", "aag", "sentinel"]
          },
          "event_type": {
            "enum": [
              "run.started",
              "agent.plan",
              "tool.requested",
              "tool.executed",
              "aag.decision",
              "approval.required",
              "worker.started",
              "worker.completed",
              "health.check",
              "adapter.tick",
              "adapter.redacted_boundary",
              "sentinel.alert",
              "sentinel.recovery",
              "run.completed"
            ]
          },
          "actor": {
            "type": "string",
            "minLength": 1
          },
          "tool": {
            "type": "string",
            "minLength": 1
          },
          "decision": {
            "type": "string",
            "minLength": 1
          },
          "risk": {
            "enum": ["low", "medium", "high"]
          },
          "status": {
            "enum": ["queued", "running", "needs_approval", "approved", "denied", "succeeded", "failed", "recovered"]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "redacted_payload_hash": {
            "type": "string",
            "pattern": "^sha256:redacted-[a-z0-9-]+$"
          },
          "parent_event_id": {
            "type": ["string", "null"]
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "href"],
              "additionalProperties": false,
              "properties": {
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "href": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
